{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [ "SimplyRugby_System/*.csproj" ],
          "exclude": [ "**/bin/**", "**/obj/**" ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "*.{md,yml}" ]
      },
      {
        "files": [ "api/**/*.yml" ],
        "dest": "api"
      }
    ],
    "resource": [
      {
        "files": [ "images/**" ]
      }
    ],
    "output": "docs",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Simply Rugby System",
      "_appTitle": "Simply Rugby System Documentation",
      "_enableSearch": true
    }
  }
}